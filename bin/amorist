#!/usr/bin/env python3
import argparse
import json
import mimetypes
import os
import secrets
import signal
import subprocess
import sys
import threading
import time
import urllib.parse
from http import HTTPStatus
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path


APP_ROOT = Path(__file__).resolve().parent.parent
WEB_ROOT = APP_ROOT / "web"
VERSION_FILE = APP_ROOT / "VERSION"
MAX_MARKDOWN_BYTES = 10 * 1024 * 1024
ALLOWED_EXTENSIONS = {".md", ".markdown", ".mdown"}


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="amorist",
        description="Open a local Markdown file in the amorist editor.",
    )
    parser.add_argument("file", nargs="?", help="Markdown file to open")
    parser.add_argument("--no-open", action="store_true", help="print the URL without opening a browser")
    parser.add_argument("--port", type=int, default=0, help="local port to bind, defaults to a free port")
    parser.add_argument("--version", action="store_true", help="print the installed amorist version")
    args = parser.parse_args()

    if args.version:
        print(read_version())
        return 0

    if not args.file:
        parser.error("missing Markdown file path")

    markdown_path = Path(args.file).expanduser().resolve()
    if markdown_path.suffix.lower() not in ALLOWED_EXTENSIONS:
        print("amorist only opens .md, .markdown, and .mdown files.", file=sys.stderr)
        return 2

    if markdown_path.exists() and markdown_path.stat().st_size > MAX_MARKDOWN_BYTES:
        print("amorist refuses to open Markdown files larger than 10 MB.", file=sys.stderr)
        return 2

    if not WEB_ROOT.exists():
        print(f"Cannot find web assets at {WEB_ROOT}. Reinstall amorist.", file=sys.stderr)
        return 1

    token = secrets.token_urlsafe(24)
    state = ServerState(markdown_path=markdown_path, token=token)

    server = ThreadingHTTPServer(("127.0.0.1", args.port), make_handler(state))
    server.daemon_threads = True
    state.server = server

    host, port = server.server_address
    url = f"http://{host}:{port}/?token={urllib.parse.quote(token)}"
    install_signal_handlers(server)
    start_heartbeat_monitor(state)

    print(f"amorist {read_version()}", flush=True)
    print(f"Editing: {markdown_path}", flush=True)
    print(f"URL: {url}", flush=True)
    print("Close the editor tab to stop this process, or press Ctrl+C.", flush=True)

    if not args.no_open:
        open_browser(url)

    try:
        server.serve_forever(poll_interval=0.25)
    except KeyboardInterrupt:
        pass
    finally:
        server.server_close()

    return 0


class ServerState:
    def __init__(self, markdown_path: Path, token: str):
        self.markdown_path = markdown_path
        self.token = token
        self.server: ThreadingHTTPServer | None = None
        self.last_ping: float | None = None
        self.close_deadline: float | None = None
        self.first_ping_seen = False
        self.shutdown_started = False
        self.lock = threading.Lock()


def make_handler(state: ServerState):
    class AmoristHandler(BaseHTTPRequestHandler):
        server_version = "amorist"

        def log_message(self, fmt: str, *args) -> None:
            if os.environ.get("AMORIST_DEBUG"):
                super().log_message(fmt, *args)

        def do_GET(self) -> None:
            parsed = urllib.parse.urlparse(self.path)
            if parsed.path in {"", "/"}:
                record_client_activity(state)
                return self.send_file(WEB_ROOT / "index.html")
            if parsed.path == "/favicon.ico":
                return self.send_file(WEB_ROOT / "favicon.ico")
            if parsed.path == "/api/document":
                return self.send_document(parsed)
            if parsed.path == "/api/version":
                return self.send_json({"version": read_version()})
            return self.send_static(parsed.path)

        def do_POST(self) -> None:
            parsed = urllib.parse.urlparse(self.path)
            if parsed.path == "/api/document":
                return self.save_document(parsed)
            if parsed.path == "/api/ping":
                return self.record_ping(parsed)
            if parsed.path == "/api/close":
                return self.record_close(parsed)
            self.send_error(HTTPStatus.NOT_FOUND)

        def send_document(self, parsed: urllib.parse.ParseResult) -> None:
            if not self.check_token(parsed):
                return
            path = state.markdown_path
            if path.exists():
                raw = path.read_bytes()
                try:
                    markdown = raw.decode("utf-8")
                except UnicodeDecodeError:
                    self.send_error(HTTPStatus.UNSUPPORTED_MEDIA_TYPE, "Markdown files must be UTF-8 encoded.")
                    return
            else:
                raw = b""
                markdown = ""

            self.send_json(
                {
                    "path": str(path),
                    "name": path.name,
                    "exists": path.exists(),
                    "lineEnding": detect_line_ending(raw),
                    "markdown": normalize_line_endings(markdown),
                }
            )

        def save_document(self, parsed: urllib.parse.ParseResult) -> None:
            if not self.check_token(parsed):
                return
            length = int(self.headers.get("Content-Length", "0"))
            if length > MAX_MARKDOWN_BYTES:
                self.send_error(HTTPStatus.REQUEST_ENTITY_TOO_LARGE)
                return

            try:
                payload = json.loads(self.rfile.read(length).decode("utf-8"))
                markdown = payload["markdown"]
                line_ending = payload.get("lineEnding", "lf")
            except (KeyError, json.JSONDecodeError, UnicodeDecodeError):
                self.send_error(HTTPStatus.BAD_REQUEST)
                return

            if not isinstance(markdown, str):
                self.send_error(HTTPStatus.BAD_REQUEST)
                return

            path = state.markdown_path
            path.parent.mkdir(parents=True, exist_ok=True)
            contents = encode_line_endings(markdown, line_ending)
            tmp_path = path.with_name(f".{path.name}.amorist-tmp")
            tmp_path.write_text(contents, encoding="utf-8", newline="")
            tmp_path.replace(path)
            self.send_json({"saved": True, "path": str(path)})

        def record_ping(self, parsed: urllib.parse.ParseResult) -> None:
            if not self.check_token(parsed):
                return
            record_client_activity(state)
            self.send_response(HTTPStatus.NO_CONTENT)
            self.end_headers()

        def record_close(self, parsed: urllib.parse.ParseResult) -> None:
            if not self.check_token(parsed):
                return
            with state.lock:
                state.close_deadline = time.time() + 5
            self.send_response(HTTPStatus.NO_CONTENT)
            self.end_headers()

        def send_static(self, request_path: str) -> None:
            relative = request_path.lstrip("/")
            if relative.startswith("web/"):
                path = APP_ROOT / relative
            else:
                self.send_error(HTTPStatus.NOT_FOUND)
                return

            try:
                resolved = path.resolve()
            except FileNotFoundError:
                self.send_error(HTTPStatus.NOT_FOUND)
                return

            web_root = WEB_ROOT.resolve()
            if not (resolved == web_root or web_root in resolved.parents):
                self.send_error(HTTPStatus.NOT_FOUND)
                return
            self.send_file(resolved)

        def send_file(self, path: Path) -> None:
            if not path.exists() or not path.is_file():
                self.send_error(HTTPStatus.NOT_FOUND)
                return
            contents = path.read_bytes()
            content_type = mimetypes.guess_type(path.name)[0] or "application/octet-stream"
            self.send_response(HTTPStatus.OK)
            self.send_header("Content-Type", content_type)
            self.send_header("Content-Length", str(len(contents)))
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            self.wfile.write(contents)

        def send_json(self, payload: dict) -> None:
            contents = json.dumps(payload).encode("utf-8")
            self.send_response(HTTPStatus.OK)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Content-Length", str(len(contents)))
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            self.wfile.write(contents)

        def check_token(self, parsed: urllib.parse.ParseResult) -> bool:
            query = urllib.parse.parse_qs(parsed.query)
            token = query.get("token", [""])[0] or self.headers.get("X-Amorist-Token", "")
            if not secrets.compare_digest(token, state.token):
                self.send_error(HTTPStatus.FORBIDDEN)
                return False
            return True

    return AmoristHandler


def detect_line_ending(raw: bytes) -> str:
    if b"\r\n" in raw:
        return "crlf"
    return "lf"


def normalize_line_endings(markdown: str) -> str:
    return markdown.replace("\r\n", "\n").replace("\r", "\n")


def encode_line_endings(markdown: str, line_ending: str) -> str:
    normalized = normalize_line_endings(markdown)
    if line_ending == "crlf":
        return normalized.replace("\n", "\r\n")
    return normalized


def read_version() -> str:
    try:
        return VERSION_FILE.read_text(encoding="utf-8").strip()
    except FileNotFoundError:
        return "0.0.0"


def open_browser(url: str) -> None:
    try:
        subprocess.Popen(
            ["xdg-open", url],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except FileNotFoundError:
        print("xdg-open is not installed; open the URL above manually.", file=sys.stderr)


def record_client_activity(state: ServerState) -> None:
    with state.lock:
        state.first_ping_seen = True
        state.last_ping = time.time()
        state.close_deadline = None


def start_heartbeat_monitor(state: ServerState) -> None:
    def monitor() -> None:
        while True:
            time.sleep(2)
            with state.lock:
                if state.shutdown_started:
                    return
                should_shutdown = (
                    state.first_ping_seen
                    and state.last_ping is not None
                    and time.time() - state.last_ping > 120
                ) or (
                    state.close_deadline is not None
                    and time.time() >= state.close_deadline
                )
                if should_shutdown:
                    state.shutdown_started = True
                    server = state.server
                else:
                    server = None
            if server is not None:
                server.shutdown()
                return

    thread = threading.Thread(target=monitor, name="amorist-heartbeat", daemon=True)
    thread.start()


def install_signal_handlers(server: ThreadingHTTPServer) -> None:
    def shutdown(_signum, _frame) -> None:
        threading.Thread(target=server.shutdown, name="amorist-signal-shutdown", daemon=True).start()

    signal.signal(signal.SIGTERM, shutdown)


if __name__ == "__main__":
    raise SystemExit(main())
