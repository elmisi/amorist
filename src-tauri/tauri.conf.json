{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "amorist",
  "version": "0.1.0",
  "identifier": "dev.elmisi.amorist",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "amorist",
        "width": 1100,
        "height": 780,
        "minWidth": 760,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "cli": {
      "description": "Open a Markdown file in amorist",
      "args": [
        {
          "name": "file",
          "index": 1,
          "takesValue": true,
          "multiple": true
        }
      ]
    }
  }
}
